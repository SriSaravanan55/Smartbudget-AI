# Copy this file to .env and fill in real values. Never commit the actual .env file.

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Database ---
# SQLite (default, good for local dev):
DATABASE_URL=sqlite:///./smartbudget.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/smartbudget

# --- Auth ---
# Generate a real secret with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-in-production-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- LLM (optional) ---
# Without this, the app uses rule-based expense categorization and templated
# report insights instead of Claude-generated ones.
ANTHROPIC_API_KEY=

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
